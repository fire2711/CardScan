# Google Cloud Vision API (for OCR - reading text off cards)
# Get at: https://console.cloud.google.com → APIs → Cloud Vision API → Credentials
GOOGLE_VISION_API_KEY=your_google_vision_key_here

# TCGAPI.dev (for Magic, Sports, and other non-Pokémon games)
# Get at: https://tcgapi.dev → Sign up → Dashboard
TCGAPI_KEY=your_tcgapi_key_here

# Pokémon TCG API (optional - increases rate limit from 1000/day to unlimited)
# Get at: https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=your_pokemon_tcg_key_here

# Port (Railway/Render sets this automatically)
PORT=3000
